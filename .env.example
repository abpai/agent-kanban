# Default provider is local.
# Set to `linear` to use the Linear-backed provider instead of SQLite.
KANBAN_PROVIDER=local

# Storage mode. Use postgres when sharing a cache with an external consumer process.
KANBAN_STORAGE=sqlite

# Postgres mode only.
KANBAN_DATABASE_URL=

# Local/Postgres mode only, optional bootstrap columns.
KANBAN_DEFAULT_COLUMNS=
KANBAN_DEFAULT_TASK_COLUMN=

# Remote providers only. Defaults to 30000; must be an integer >= 1000.
KANBAN_SYNC_INTERVAL_MS=30000

# SQLite mode only.
# Override the SQLite database path if you do not want the default `.kanban/board.db`.
KANBAN_DB_PATH=.kanban/board.db

# Linear mode only.
# Required when `KANBAN_PROVIDER=linear`.
LINEAR_API_KEY=

# Linear mode only.
# Required when `KANBAN_PROVIDER=linear`.
LINEAR_TEAM_ID=

# Jira provider (KANBAN_PROVIDER=jira)
# Atlassian site base URL (no trailing slash).
JIRA_BASE_URL=

# Jira mode only.
# Atlassian account email for HTTP Basic auth.
JIRA_EMAIL=

# Jira mode only.
# Atlassian API token (https://id.atlassian.com/manage-profile/security/api-tokens).
JIRA_API_TOKEN=

# Jira mode only.
# Project key to scope the kanban (e.g. ENG).
JIRA_PROJECT_KEY=

# Jira mode only, optional.
# Agile board id to use for ordered kanban columns. Falls back to project statuses if unset.
JIRA_BOARD_ID=

# Jira mode only, optional.
# Default issue type for created tasks (default: Task).
JIRA_ISSUE_TYPE=

# Webhook HMAC secrets. When set, the matching signature is required. When
# unset, Linear/Jira webhook endpoints accept unsigned payloads in local open
# dev mode; `kanban serve --tunnel` refuses to start for those providers unless
# the matching secret is set.
# Linear: HMAC-SHA256 hex in the `Linear-Signature` header.
# Jira: WebSub-style HMAC signature in the `X-Hub-Signature` header.
LINEAR_WEBHOOK_SECRET=
JIRA_WEBHOOK_SECRET=
